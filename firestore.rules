rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    function isSignedIn() {

      return request.auth != null;

    }



    function userDoc() {

      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;

    }



    function userCoupleId() {

      return userDoc().coupleId;

    }



    function isCoupleMember(coupleId) {

      return isSignedIn() &&

        userCoupleId() == coupleId &&

        request.auth.uid in memberIds(

          get(/databases/$(database)/documents/couples/$(coupleId)).data

        );

    }



    function memberIds(data) {

      return data.memberIds is list ? data.memberIds : [];

    }



    function canJoinCouple(data) {

      return isSignedIn() &&

        memberIds(data).size() < 2 &&

        !(request.auth.uid in memberIds(data));

    }



    function isPartnerOf(userId) {

      let myCoupleId = userCoupleId();

      return isSignedIn() &&

        userId != request.auth.uid &&

        myCoupleId != null &&

        myCoupleId is string &&

        myCoupleId.size() == 6 &&

        userId in memberIds(

          get(/databases/$(database)/documents/couples/$(myCoupleId)).data

        );

    }



    match /users/{userId} {

      allow read: if isSignedIn() && (

        request.auth.uid == userId ||

        isPartnerOf(userId)

      );



      allow create, update: if isSignedIn() && request.auth.uid == userId;



      allow update: if isSignedIn() &&

        isPartnerOf(userId) &&

        request.resource.data.diff(resource.data).affectedKeys()

          .hasOnly(['nickname', 'nicknameSetBy']);



      match /alerts/{alertId} {

        allow read, update: if isSignedIn() && request.auth.uid == userId;

        allow create: if isSignedIn() && isPartnerOf(userId);

        allow delete: if isSignedIn() && request.auth.uid == userId;

      }

    }



    match /couples/{coupleId} {

      allow get: if isSignedIn() && (

        resource == null ||

        request.auth.uid in memberIds(resource.data) ||

        memberIds(resource.data).size() < 2

      );



      allow list: if false;



      allow create: if isSignedIn() &&

        coupleId == request.resource.data.code &&

        request.auth.uid in memberIds(request.resource.data) &&

        memberIds(request.resource.data).size() == 1;



      allow update: if isSignedIn() && (

        request.auth.uid in memberIds(resource.data) ||

        (

          canJoinCouple(resource.data) &&

          request.auth.uid in memberIds(request.resource.data) &&

          memberIds(request.resource.data).size() <= 2 &&

          resource.data.code == request.resource.data.code

        )

      );



      allow delete: if false;



      match /memories/{memoryId} {

        allow read, write: if isCoupleMember(coupleId);

      }



      match /messages/{messageId} {

        allow read: if isCoupleMember(coupleId);

        allow create: if isCoupleMember(coupleId) &&

          request.resource.data.senderId == request.auth.uid;

        allow update, delete: if false;

      }

    }

  }

}

